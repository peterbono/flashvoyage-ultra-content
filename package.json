{
  "name": "flashvoyage-ultra-content",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "publish:article": "node enhanced-ultra-generator.js",
    "start:ultra-generator": "node ultra-specialized-content-generator.js",
    "start:auto-publisher": "node fixed-auto-publisher.js",
    "start:daily-content": "./start-daily-content.sh",
    "test:ultra-content": "node test-ultra-content.js",
    "test:widgets": "node scripts/test-travelpayouts-widgets-database.js && node scripts/test-widget-placer-integration.js && node scripts/test-affiliate-module-renderer.js && node scripts/test-finalizer-widget-replacement.js",
    "start:all": "concurrently \"npm run start:ultra-generator\" \"npm run start:auto-publisher\"",
    "dev": "vercel dev",
    "build": "vercel build",
    "deploy": "vercel --prod",
    "seo:generate": "node scripts/generate-seo-pages.js",
    "seo:status": "node scripts/generate-seo-pages.js --status",
    "refresh:articles": "node scripts/refresh-articles.js",
    "sitemap:generate": "node scripts/generate-sitemap.js",
    "sitemap:submit": "node scripts/generate-sitemap.js --submit",
    "trends:report": "node social-distributor/sources/trends-scanner.js report",
    "trends:scan": "node social-distributor/sources/trends-scanner.js scan",
    "trends:update-reels": "node social-distributor/sources/trends-scanner.js update-reels",
    "trends:deepdive": "node social-distributor/sources/trends-scanner.js deepdive",
    "intelligence:full": "node social-distributor/analytics/content-intelligence-engine.js full",
    "intelligence:quick": "node social-distributor/analytics/content-intelligence-engine.js quick",
    "intelligence:daily": "node social-distributor/analytics/content-intelligence-engine.js daily",
    "intelligence:summary": "node social-distributor/analytics/content-intelligence-engine.js summary",
    "intelligence:score": "node social-distributor/analytics/article-scorer.js score",
    "intelligence:gaps": "node social-distributor/analytics/content-gap-detector.js analyze",
    "intelligence:fruit": "node social-distributor/analytics/search-console-fetcher.js fruit",
    "intelligence:revenue": "node social-distributor/analytics/revenue-tracker.js report",
    "intelligence:refresh": "node social-distributor/analytics/content-refresh-engine.js detect",
    "intelligence:reel-route": "node social-distributor/analytics/article-reel-router.js test-all",
    "digest": "node scripts/daily-digest-generator.js --stdout",
    "digest:file": "node scripts/daily-digest-generator.js --file",
    "digest:json": "node scripts/daily-digest-generator.js --json",
    "digest:subject": "node scripts/daily-digest-generator.js --subject"
  },
  "keywords": [
    "flashvoyage",
    "content",
    "automation",
    "travel",
    "asia"
  ],
  "author": "FlashVoyages",
  "license": "ISC",
  "description": "Système de génération de contenu ultra-spécialisé pour FlashVoyages",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@google-analytics/data": "^5.2.1",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.7.2",
    "cheerio": "^1.1.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "debug": "^4.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "form-data": "^4.0.4",
    "google-trends-api": "^4.9.2",
    "googleapis": "^171.4.0",
    "node-html-parser": "^7.0.2",
    "node-html-to-image": "^5.0.0",
    "openai": "^6.3.0",
    "ws": "^8.19.0",
    "xml2js": "^0.6.2"
  }
}
